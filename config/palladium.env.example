# Site server
SITE_HOST=0.0.0.0
SITE_PORT=3000
CORS_ORIGIN=*
FRONTEND_DIR=.
GAMES_DIR=games
REQUEST_TIMEOUT_MS=25000
MAX_REQUEST_BODY_BYTES=131072
AI_REQUEST_TIMEOUT_MS=120000
MONOCHROME_BASE_URL=https://monochrome.tf

# Ollama AI
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_AUTOSTART=true
OLLAMA_COMMAND=ollama
OLLAMA_STARTUP_TIMEOUT_SECONDS=45
OLLAMA_PULL_MODEL_ON_START=true
OLLAMA_PULL_TIMEOUT_SECONDS=600

# Scramjet proxy sidecar
SCRAMJET_AUTOSTART=true
SCRAMJET_DIR=scramjet-service
SCRAMJET_NODE_COMMAND=node
SCRAMJET_NPM_COMMAND=npm
SCRAMJET_HOST=0.0.0.0
SCRAMJET_PORT=1337
SCRAMJET_INSTALL_DEPS=true
SCRAMJET_INSTALL_TIMEOUT_SECONDS=300
SCRAMJET_STARTUP_TIMEOUT_SECONDS=20

# Discord bots
DISCORD_BOTS_AUTOSTART=true
DISCORD_BOTS_DIR=discord-bots
DISCORD_BOTS_NODE_COMMAND=node
DISCORD_BOTS_STARTUP_GRACE_SECONDS=5
DISCORD_API_BASE=https://discord.com/api/v10
DISCORD_GUILD_ID=
DISCORD_RULES_TEXT=
DISCORD_COMMUNITY_GATEWAY_INTENTS=3
DISCORD_MODERATION_ENABLED=true
DISCORD_MODERATION_TIMEOUT_MINUTES=15
DISCORD_MODERATION_LOOKBACK_MS=12000
DISCORD_MODERATION_MAX_MESSAGES=6
DISCORD_MODERATION_COOLDOWN_MS=600000
DISCORD_MODERATION_USE_QWEN=true
DISCORD_MODERATION_QWEN_TIMEOUT_MS=8000
DISCORD_MODERATION_CHANNEL_IDS=

# Tokens
DISCORD_COMMIT_BOT_TOKEN=
DISCORD_LINK_BOT_TOKEN=
DISCORD_COMMUNITY_BOT_TOKEN=

