# Site server
SITE_HOST=0.0.0.0
SITE_PORT=443
CORS_ORIGIN=*
# Optional: point this at a local frontend checkout if you want the backend
# to serve static UI files too. When missing, the backend still runs in
# backend-only mode and keeps API/game routes online.
# Set to `disabled` to force backend-only mode.
FRONTEND_DIR=../frontend
GAMES_DIR=games
SWF_DIR=swf
GAME_IMAGE_DIR=images/game-img
GAME_CATALOG_PATH=config/game-catalog.json
REQUEST_TIMEOUT_MS=25000
MAX_REQUEST_BODY_BYTES=131072
AI_REQUEST_TIMEOUT_MS=120000
MONOCHROME_BASE_URL=https://monochrome.tf
PLAY_STATS_PATH=config/game-play-stats.json

# Ollama AI
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_AUTOSTART=true
OLLAMA_COMMAND=ollama
OLLAMA_STARTUP_TIMEOUT_SECONDS=45
OLLAMA_PULL_MODEL_ON_START=true
OLLAMA_PULL_TIMEOUT_SECONDS=600

# External proxy UI endpoint (for proxy.html iframe)
# Example: https://sethpang.com
PROXY_BASE_URL=

# Discord page widget + invite
DISCORD_WIDGET_URL=https://discord.com/api/guilds/1479914434460913707/widget.json
DISCORD_INVITE_URL=https://discord.gg/FNACSCcE26

# Discord bots
DISCORD_BOTS_AUTOSTART=true
DISCORD_BOTS_DIR=discord-bots
DISCORD_BOTS_NODE_COMMAND=node
DISCORD_BOTS_STARTUP_GRACE_SECONDS=5
DISCORD_API_BASE=https://discord.com/api/v10
DISCORD_GUILD_ID=
DISCORD_RULES_TEXT=
DISCORD_COMMUNITY_POLL_MS=30000
DISCORD_MEMBER_SYNC_MS=120000
DISCORD_RULES_CHECK_MS=300000
DISCORD_ROLE_CACHE_MS=600000
DISCORD_COMMUNITY_GATEWAY_INTENTS=1
DISCORD_MODERATION_ENABLED=true
DISCORD_MODERATION_TIMEOUT_MINUTES=15
DISCORD_MODERATION_LOOKBACK_MS=12000
DISCORD_MODERATION_MAX_MESSAGES=6
DISCORD_MODERATION_COOLDOWN_MS=600000
DISCORD_MODERATION_USE_QWEN=true
DISCORD_MODERATION_QWEN_TIMEOUT_MS=8000
DISCORD_MODERATION_CHANNEL_IDS=

# Tokens
DISCORD_COMMIT_BOT_TOKEN=
DISCORD_LINK_BOT_TOKEN=
DISCORD_COMMUNITY_BOT_TOKEN=

# Channels
DISCORD_COMMIT_CHANNEL_ID=1480022214303682700
# Strongly recommended for reliable commit tracking:
DISCORD_COMMIT_REPO=Palladium-Games/Palladium-Games
DISCORD_COMMIT_BRANCH=main
# If you do not set DISCORD_COMMIT_GITHUB_TOKEN, commit polling defaults to a slower interval.
# DISCORD_COMMIT_GITHUB_TOKEN=
# DISCORD_COMMIT_POLL_MS=120000
# Optional commit bot remote tracking settings
# DISCORD_COMMIT_REPO=Palladium-Games/Palladium-Games
# DISCORD_COMMIT_BRANCH=main
# DISCORD_COMMIT_POLL_MS=15000
# DISCORD_COMMIT_GITHUB_TOKEN=
# DISCORD_COMMIT_POST_ON_BOOTSTRAP=true
# DISCORD_COMMIT_BOOTSTRAP_POST_COUNT=1
# Commit update pings (defaults to role name "Dev Following")
# DISCORD_COMMIT_PING_ROLE_NAME=Dev Following
# DISCORD_COMMIT_PING_ROLE_ID=
# Link bot behavior (slash-command mode by default)
DISCORD_LINK_LEGACY_POLLING_ENABLED=false
DISCORD_LINK_POLL_MS=60000
DISCORD_LINK_COMMAND_SYNC_MS=3600000
DISCORD_LINK_COMMAND_CHANNEL_IDS=1480327216826155059,1480329637660983408
DISCORD_WELCOME_CHANNEL_ID=1480334877961355304
DISCORD_RULES_CHANNEL_ID=1480324913561862184

# Auto-update from git
GIT_AUTO_PULL_ENABLED=false
GIT_AUTO_PULL_REMOTE=origin
GIT_AUTO_PULL_BRANCH=
GIT_AUTO_PULL_INTERVAL_MS=120000
GIT_AUTO_PULL_COMMAND_TIMEOUT_MS=90000
